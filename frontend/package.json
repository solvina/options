{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:api": "npm run generate:health && npm run generate:account && npm run generate:spreads && npm run generate:diagnostic && npm run generate:universe",
    "generate:health": "openapi-ts -i ../engine/openapi/cz.solvina.options.health.yaml -o ./src/generated/health -c @hey-api/client-fetch -p @tanstack/react-query",
    "generate:account": "openapi-ts -i ../engine/openapi/cz.solvina.options.account.yaml -o ./src/generated/account -c @hey-api/client-fetch -p @tanstack/react-query",
    "generate:spreads": "openapi-ts -i ../engine/openapi/cz.solvina.options.spreads.yaml -o ./src/generated/spreads -c @hey-api/client-fetch -p @tanstack/react-query",
    "generate:diagnostic": "openapi-ts -i ../engine/openapi/cz.solvina.options.diagnostic.yaml -o ./src/generated/diagnostic -c @hey-api/client-fetch -p @tanstack/react-query",
    "generate:universe": "openapi-ts -i ../engine/openapi/cz.solvina.options.universe.yaml -o ./src/generated/universe -c @hey-api/client-fetch -p @tanstack/react-query"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@hey-api/openapi-ts": "^0.91.1",
    "@types/node": "^25.2.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.0.0"
  }
}
